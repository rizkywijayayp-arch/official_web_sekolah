# ========================================
# KONFIGURASI WEBSITE SEKOLAH
# ========================================
# Ikuti langkah di DEPLOYMENT_GUIDE.md untuk panduan lengkap

# API Base URL (biarkan seperti ini - jangan diubah)
VITE_API_BASE_URL=https://be-school.kiraproject.id

# School ID (dari admin - ini unik untuk setiap sekolah)
VITE_SCHOOL_ID=55

# API Key (dari admin - JANGAN BERITAHUAN ORANG LAIN!)
VITE_API_KEY=ISI_API_KEY_YANG_DIBERIKAN_ADMIN

# Optional: Analytics ID (kalau ada)
# VITE_GA_ID=G-XXXXXXXXXX