# API Base URL (nginx proxy /api → backend)
VITE_API_BASE_URL=https://be-school.kiraproject.id

# Default School ID fallback (override per deployment via VITE_DEFAULT_SCHOOL_ID)
VITE_DEFAULT_SCHOOL_ID=1001

# Admin Portal URL
VITE_ADMIN_PORTAL_URL=https://admin.kiraproject.id

# Optional: Analytics ID
# VITE_GA_ID=G-XXXXXXXXXX